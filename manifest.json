{
  "manifest_version": 3,
  "name": "Stitch Export",
  "version": "1.2.0",
  "author": "nsozturk <telepenu@gmail.com>",
  "description": "Export Stitch conversations in LLM-compatible formats (Claude Code, OpenAI ChatGPT)",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://stitch.withgoogle.com/*",
    "https://*.appspot.com/*",
    "https://contribution.usercontent.google.com/*",
    "https://lh3.googleusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://stitch.withgoogle.com/*",
        "https://*.appspot.com/*"
      ],
      "js": [
        "utils/extractor.js",
        "utils/formatters.js",
        "utils/downloader.js",
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}